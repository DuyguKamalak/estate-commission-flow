# --- Application ------------------------------------------------------------
NODE_ENV=development
PORT=3001
API_PREFIX=api

# --- CORS -------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000

# --- MongoDB Atlas ----------------------------------------------------------
# Required in development and production. Optional only when NODE_ENV=test.
# Example: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/estate-commission-flow?retryWrites=true&w=majority
MONGODB_URI=

# --- Business defaults ------------------------------------------------------
DEFAULT_CURRENCY=GBP
